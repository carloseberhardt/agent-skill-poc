# LiteLLM proxy connection
# The proxy uses virtual keys and virtual model names.
# Run litellm-proxy/scripts/setup-teams.sh to create teams and keys,
# then source /tmp/litellm-keys.env to get the values below.
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=sk-your-virtual-key-here
LITELLM_MODEL=claude-sonnet-team-b

# Agent Gateway (A2A + MCP gateway)
AGENT_GATEWAY_URL=http://localhost:3000
AGENT_GATEWAY_MCP_URL=http://localhost:3000/mcp
AGENT_GATEWAY_A2A_AGENTS=data-agent,security-agent

# Demo mode — overrides all scheduled skills to fire every minute
# DEMO_MODE=true
